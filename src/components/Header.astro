---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getHomePath, getTranslations, type Lang } from '../i18n';
import { withBase } from '../utils/url';

interface Props {
  currentPath: string;
  lang: Lang;
}

const { currentPath, lang } = Astro.props;
const t = getTranslations(lang);
const nav = t.nav;
const homePath = getHomePath(lang);

function isActive(href: string) {
  const normalized = href.replace(/\/$/, '') || (lang === 'en' ? '/en' : '/');
  const path = currentPath.replace(/\/$/, '') || (lang === 'en' ? '/en' : '/');
  if (normalized === homePath) return path === homePath;
  return path === normalized || path.startsWith(`${normalized}/`);
}

function isDocsActive() {
  const docsBase = lang === 'de' ? '/docs' : '/en/docs';
  return currentPath.startsWith(docsBase);
}

const linkClass = (active: boolean) =>
  active ? 'text-cyan-300/90' : 'text-neutral-500 hover:text-cyan-300/90';

const mobileLinkClass = (active: boolean) =>
  active ? 'text-cyan-300/90' : 'text-neutral-300';

const docsOverviewPath = lang === 'de' ? '/docs' : '/en/docs';
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 border-b border-white/[0.06] bg-[#030308]/80 backdrop-blur-xl supports-[padding:max(0px)]:pt-[env(safe-area-inset-top)]"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-8 sm:py-5">
    <a
      href={withBase(homePath)}
      class="brand-link inline-flex shrink-0 items-center gap-2.5"
      aria-current={isActive(homePath) ? 'page' : undefined}
    >
      <img
        src={withBase('logo.png')}
        alt=""
        class="brand-asset h-9 w-9"
        width="36"
        height="36"
        decoding="async"
        aria-hidden="true"
      />
      <span class="brand-wordmark text-sm font-extrabold tracking-tight sm:text-base">
        <span class="text-white">Blueprint</span><span class="text-[#3b82f6]">Studio</span>
      </span>
    </a>

    <div class="hidden items-center gap-6 lg:flex">
      <nav aria-label={t.ui.navMain}>
        <ul class="flex items-center justify-end gap-x-6">
          {
            nav.map((item) =>
              item.children ? (
                <li class="group relative">
                  <a
                    href={withBase(item.href)}
                    class:list={['text-sm font-light transition-colors', linkClass(isDocsActive())]}
                    aria-current={isDocsActive() ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                  <ul
                    class="invisible absolute right-0 top-full z-50 mt-2 min-w-[11rem] rounded-xl border border-white/10 bg-[#0a0a12]/95 py-2 opacity-0 backdrop-blur-xl transition-[opacity,visibility] duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
                    role="list"
                  >
                    {
                      item.children.map((child) => (
                        <li>
                          <a
                            href={withBase(child.href)}
                            class:list={[
                              'block px-4 py-2.5 text-sm font-light transition-colors',
                              isActive(child.href)
                                ? 'text-cyan-300/90'
                                : 'text-neutral-400 hover:text-white',
                            ]}
                          >
                            {child.label}
                          </a>
                        </li>
                      ))
                    }
                  </ul>
                </li>
              ) : (
                <li>
                  <a
                    href={withBase(item.href)}
                    class:list={['text-sm font-light transition-colors', linkClass(isActive(item.href))]}
                    aria-current={isActive(item.href) ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              ),
            )
          }
        </ul>
      </nav>
      <LanguageSwitcher currentPath={currentPath} lang={lang} />
    </div>

    <div class="flex items-center gap-3 lg:hidden">
      <LanguageSwitcher currentPath={currentPath} lang={lang} />
      <button
        type="button"
        id="nav-toggle"
        class="nav-toggle"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label={t.ui.menuOpen}
        data-label-open={t.ui.menuOpen}
        data-label-close={t.ui.menuClose}
      >
        <span class="nav-toggle-bar" aria-hidden="true"></span>
        <span class="nav-toggle-bar" aria-hidden="true"></span>
        <span class="nav-toggle-bar" aria-hidden="true"></span>
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="mobile-nav-panel lg:hidden" hidden aria-hidden="true">
    <nav aria-label={t.ui.navMobile}>
      <ul class="space-y-1 px-4 pb-6 sm:px-8" role="list">
        {
          nav.map((item) =>
            item.children ? (
              <li>
                <details class="mobile-nav-details" open={isDocsActive()}>
                  <summary
                    class:list={[
                      'mobile-nav-link flex cursor-pointer list-none items-center justify-between',
                      mobileLinkClass(isDocsActive()),
                    ]}
                  >
                    <span>{item.label}</span>
                    <svg
                      class="mobile-nav-chevron h-4 w-4 shrink-0 text-neutral-500"
                      viewBox="0 0 16 16"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path
                        d="M4 6l4 4 4-4"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                    </svg>
                  </summary>
                  <ul class="mb-2 ml-3 space-y-1 border-l border-white/10 pl-4" role="list">
                    <li>
                      <a
                        href={withBase(docsOverviewPath)}
                        class:list={[
                          'mobile-nav-sublink block',
                          mobileLinkClass(currentPath === docsOverviewPath),
                        ]}
                      >
                        {t.ui.docsOverview}
                      </a>
                    </li>
                    {
                      item.children.map((child) => (
                        <li>
                          <a
                            href={withBase(child.href)}
                            class:list={['mobile-nav-sublink block', mobileLinkClass(isActive(child.href))]}
                          >
                            {child.label}
                          </a>
                        </li>
                      ))
                    }
                  </ul>
                </details>
              </li>
            ) : (
              <li>
                <a
                  href={withBase(item.href)}
                  class:list={['mobile-nav-link block', mobileLinkClass(isActive(item.href))]}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ),
          )
        }
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    const toggle = document.getElementById('nav-toggle');
    const panel = document.getElementById('mobile-nav');
    if (!toggle || !panel) return;

    let isOpen = false;
    const labelOpen = toggle.getAttribute('data-label-open') || 'Open menu';
    const labelClose = toggle.getAttribute('data-label-close') || 'Close menu';

    function setOpen(open) {
      isOpen = open;
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? labelClose : labelOpen);
      toggle.classList.toggle('is-open', open);
      panel.hidden = !open;
      panel.setAttribute('aria-hidden', String(!open));
      document.body.classList.toggle('nav-open', open);
    }

    toggle.addEventListener('click', () => setOpen(!isOpen));
    panel.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && isOpen) setOpen(false);
    });
    window.matchMedia('(min-width: 1024px)').addEventListener('change', (event) => {
      if (event.matches && isOpen) setOpen(false);
    });
  })();
</script>
