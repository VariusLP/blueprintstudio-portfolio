---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contactEmail, impressumData } from '../../data/config';
import { getTranslations, type Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const p = t.impressumPage;
const country = lang === 'de' ? impressumData.countryDe : impressumData.countryEn;
const profession =
  lang === 'de'
    ? 'Full-Cycle Software & Solutions Developer (Freelancer)'
    : 'Full-Cycle Software & Solutions Developer (Freelancer)';
---

<BaseLayout title={p.title} description={p.description} lang={lang}>
  <section class="px-4 pb-24 pt-28 sm:px-8 sm:pb-28 sm:pt-32" aria-labelledby="impressum-title">
    <div class="mx-auto max-w-3xl">
      <p class="accent-label mb-4">{p.label}</p>
      <h1 id="impressum-title" class="section-title">{p.heading}</h1>
      <p class="mt-6 text-sm font-light text-neutral-500">{p.legalBasis}</p>

      <div class="mt-16 space-y-12">
        <div>
          <h2 class="accent-label mb-4">{p.publisher}</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-300">{impressumData.owner}</p>
        </div>

        <div>
          <h2 class="accent-label mb-4">{p.tradeName}</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-300">
            {impressumData.tradeName} {p.tradeNameNote}
          </p>
        </div>

        <div>
          <h2 class="accent-label mb-4">{p.profession}</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-300">{profession}</p>
        </div>

        <div>
          <h2 class="accent-label mb-4">{p.address}</h2>
          <address class="not-italic text-sm font-light leading-relaxed text-neutral-300">
            {impressumData.street}<br />
            {impressumData.zip} {impressumData.city}<br />
            {country}
          </address>
        </div>

        <div>
          <h2 class="accent-label mb-4">{p.contact}</h2>
          <p class="text-sm font-light text-neutral-300">
            {p.emailLabel}:
            <a href={`mailto:${contactEmail}`} class="text-neutral-100 hover:text-cyan-300/90">
              {contactEmail}
            </a>
          </p>
        </div>

        <div>
          <h2 class="accent-label mb-4">{p.companyRegister}</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-400">{p.companyRegisterText}</p>
        </div>

        <div>
          <h2 class="accent-label mb-4">{p.vat}</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-400">{p.vatText}</p>
        </div>

        <div class="bento-cell">
          <h2 class="accent-label mb-4">{p.privacy}</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-500">{p.privacyText}</p>
          <h2 class="accent-label mb-4 mt-8">{p.liabilityContent}</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-500">{p.liabilityContentText}</p>
          <h2 class="accent-label mb-4 mt-8">{p.liabilityLinks}</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-500">{p.liabilityLinksText}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
