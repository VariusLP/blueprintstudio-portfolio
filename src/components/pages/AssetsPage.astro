---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDocSlugPath, getDocsPath, getTranslations, type Lang } from '../../i18n';
import { withBase } from '../../utils/url';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const p = t.assetsPage;
---

<BaseLayout title={p.title} description={p.description} lang={lang}>
  <section class="px-4 pb-24 pt-28 sm:px-8 sm:pb-28 sm:pt-32" aria-labelledby="assets-title">
    <div class="mx-auto max-w-7xl">
      <p class="accent-label mb-4">{p.label}</p>
      <h1 id="assets-title" class="section-title">{p.heading}</h1>
      <p class="mt-8 max-w-2xl text-sm font-light leading-relaxed text-neutral-400">{p.intro}</p>

      <ul class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-2 sm:mt-16" role="list">
        {
          t.assets.map((asset) => (
            <li class="bento-cell">
              <p class="accent-label">{asset.version}</p>
              <h2 class="mt-2 text-xl font-extrabold text-neutral-50">{asset.name}</h2>
              <p class="mt-4 text-sm font-light leading-relaxed text-neutral-400">{asset.summary}</p>
              <ul class="detail-list mt-6" role="list">
                {asset.features.map((feature) => (
                  <li>{feature}</li>
                ))}
              </ul>
              <div class="mt-8 flex flex-wrap gap-3">
                <a href={asset.storeUrl} class="btn-ghost" rel="noopener noreferrer">
                  {t.ui.unityAssetStore}
                </a>
                <a href={withBase(getDocSlugPath(lang, asset.slug))} class="btn-ghost">
                  {t.ui.documentation}
                </a>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
