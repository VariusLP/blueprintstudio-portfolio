---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { githubHandle, githubUrl } from '../../data/config';
import { getTranslations, type Lang } from '../../i18n';
import { withBase } from '../../utils/url';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const p = t.portfolioPage;

function projectHref(project: (typeof t.portfolioProjects)[number]) {
  if (project.url) return project.url;
  if (project.internalUrl) return withBase(project.internalUrl);
  return undefined;
}
---

<BaseLayout title={p.title} description={p.description} lang={lang}>
  <section class="px-4 pb-16 pt-28 sm:px-8 sm:pt-32" aria-labelledby="portfolio-title">
    <div class="mx-auto max-w-7xl">
      <p class="accent-label mb-4">{p.label}</p>
      <h1 id="portfolio-title" class="section-title">{p.heading}</h1>
      <p class="mt-8 max-w-2xl text-sm font-light leading-relaxed text-neutral-400">{p.intro}</p>
      <p class="mt-4 max-w-2xl text-sm font-light leading-relaxed text-neutral-500">{p.workflow}</p>
      <a href={githubUrl} class="btn-ghost mt-10" target="_blank" rel="noopener noreferrer">
        github.com/{githubHandle}
      </a>
    </div>
  </section>

  <section class="px-4 pb-24 sm:px-8 sm:pb-28" aria-labelledby="projects-title">
    <div class="mx-auto max-w-7xl">
      <h2 id="projects-title" class="accent-label mb-8">{t.ui.projects}</h2>
      <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2" role="list">
        {
          t.portfolioProjects.map((project) => {
            const href = projectHref(project);
            const external = Boolean(project.url);
            return (
              <li class="bento-cell">
                <p class="accent-label">{project.type}</p>
                <h3 class="mt-2 text-base font-extrabold text-neutral-100">
                  {
                    href ? (
                      <a
                        href={href}
                        class="hover:text-cyan-300/90"
                        target={external ? '_blank' : undefined}
                        rel={external ? 'noopener noreferrer' : undefined}
                      >
                        {project.name}
                      </a>
                    ) : (
                      project.name
                    )
                  }
                </h3>
                <p class="mt-3 text-sm font-light leading-relaxed text-neutral-500">
                  {project.description}
                </p>
                <ul class="mt-4 flex flex-wrap gap-2" role="list">
                  {project.tags.map((tag) => (
                    <li class="tag">{tag}</li>
                  ))}
                </ul>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>
</BaseLayout>
