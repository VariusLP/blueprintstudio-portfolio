---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDocsPath, getDocSlugPath, getTranslations, type Lang } from '../../i18n';
import { withBase } from '../../utils/url';
import type { AssetItem } from '../../i18n/types';

interface Props {
  lang: Lang;
  doc: AssetItem;
}

const { lang, doc } = Astro.props;
const t = getTranslations(lang);
const otherDocs = t.assets.filter((d) => d.slug !== doc.slug);
---

<BaseLayout title={doc.name} description={doc.summary} lang={lang}>
  <section class="px-4 pb-24 pt-28 sm:px-8 sm:pb-28 sm:pt-32" aria-labelledby="doc-title">
    <div class="mx-auto max-w-3xl">
      <p class="accent-label mb-4">
        <a href={withBase(getDocsPath(lang))} class="hover:text-cyan-300/90">{t.ui.documentation}</a>
        {' / '}
        {doc.name}
      </p>
      <h1 id="doc-title" class="section-title">{doc.name}</h1>
      <p class="mt-6 text-sm font-light leading-relaxed text-neutral-400">{doc.summary}</p>

      <div class="mt-16 space-y-6">
        {
          doc.sections.map((section) => (
            <article class="bento-cell">
              <h2 class="text-base font-extrabold text-neutral-100">{section.title}</h2>
              <p class="mt-4 text-sm font-light leading-relaxed text-neutral-500">{section.content}</p>
            </article>
          ))
        }
      </div>

      {
        otherDocs.length > 0 && (
          <div class="mt-16">
            <p class="accent-label mb-4">{t.ui.otherDocs}</p>
            <ul class="space-y-2 text-sm font-light" role="list">
              {otherDocs.map((other) => (
                <li>
                  <a
                    href={withBase(getDocSlugPath(lang, other.slug))}
                    class="text-neutral-400 hover:text-cyan-300/90"
                  >
                    {other.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
