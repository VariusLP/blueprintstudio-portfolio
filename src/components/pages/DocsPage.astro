---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getDocSlugPath, getTranslations, type Lang } from '../../i18n';
import { withBase } from '../../utils/url';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const p = t.docsPage;
---

<BaseLayout title={p.title} description={p.description} lang={lang}>
  <section class="px-4 pb-24 pt-28 sm:px-8 sm:pb-28 sm:pt-32" aria-labelledby="docs-title">
    <div class="mx-auto max-w-7xl">
      <p class="accent-label mb-4">{p.label}</p>
      <h1 id="docs-title" class="section-title">{p.heading}</h1>
      <p class="mt-8 max-w-2xl text-sm font-light leading-relaxed text-neutral-400">{p.intro}</p>

      <ul class="mt-16 grid grid-cols-1 gap-4 sm:grid-cols-2" role="list">
        {
          t.assets.map((doc) => (
            <li class="bento-cell">
              <h2 class="text-lg font-extrabold text-neutral-100">
                <a href={withBase(getDocSlugPath(lang, doc.slug))} class="hover:text-cyan-300/90">
                  {doc.name}
                </a>
              </h2>
              <p class="mt-4 text-sm font-light leading-relaxed text-neutral-500">{doc.summary}</p>
              <a href={withBase(getDocSlugPath(lang, doc.slug))} class="btn-ghost mt-8">
                {t.ui.openGuide}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
