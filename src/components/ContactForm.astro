---
import { contactEmail, web3formsAccessKey } from '../data/config';
import { getTranslations, type Lang } from '../i18n';
import { withBase } from '../utils/url';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const cf = t.contactForm;

const formConfigured = web3formsAccessKey.length > 0;
const contactPath = lang === 'de' ? '/kontakt' : '/en/contact';
const redirectUrl = new URL(withBase(`${contactPath}?sent=1`), import.meta.env.SITE).href;
---

<form
  id="contact-form"
  class="space-y-5"
  action={formConfigured ? 'https://api.web3forms.com/submit' : undefined}
  method={formConfigured ? 'POST' : undefined}
>
  {formConfigured && (
    <>
      <input type="hidden" name="access_key" value={web3formsAccessKey} />
      <input type="hidden" name="subject" value={cf.subject} />
      <input type="hidden" name="from_name" value={cf.fromName} />
      <input type="hidden" name="redirect" value={redirectUrl} />
    </>
  )}

  <input
    type="checkbox"
    name="botcheck"
    class="hidden"
    tabindex="-1"
    autocomplete="off"
    aria-hidden="true"
  />

  <div>
    <label for="name" class="accent-label">{cf.name}</label>
    <input id="name" name="name" type="text" required class="form-input mt-2" />
  </div>

  <div>
    <label for="email" class="accent-label">{cf.email}</label>
    <input id="email" name="email" type="email" required class="form-input mt-2" />
  </div>

  <div>
    <label for="message" class="accent-label">{cf.message}</label>
    <textarea id="message" name="message" rows="6" required class="form-input mt-2 resize-y"></textarea>
  </div>

  <p
    id="form-status"
    class="hidden text-sm font-light"
    role="status"
    aria-live="polite"
  ></p>

  <button type="submit" id="submit-btn" class="btn-ghost">{cf.submit}</button>

  <p class="text-xs font-light text-neutral-600">
    {
      formConfigured
        ? cf.hintConfigured
        : `${cf.hintNotConfigured} ${contactEmail}.`
    }
  </p>
</form>

<script
  is:inline
  define:vars={{
    contactEmail,
    web3formsAccessKey,
    formConfigured,
    redirectUrl,
    cf,
  }}
>
  const form = document.getElementById('contact-form');
  const statusEl = document.getElementById('form-status');
  const submitBtn = document.getElementById('submit-btn');

  function showStatus(message, type) {
    if (!statusEl) return;
    statusEl.textContent = message;
    statusEl.classList.remove('hidden', 'text-cyan-300/90', 'text-red-400/90', 'text-amber-300/90');
    if (type === 'success') statusEl.classList.add('text-cyan-300/90');
    else if (type === 'error') statusEl.classList.add('text-red-400/90');
    else statusEl.classList.add('text-amber-300/90');
  }

  function openMailto() {
    const data = new FormData(form);
    const name = String(data.get('name') ?? '').trim();
    const email = String(data.get('email') ?? '').trim();
    const message = String(data.get('message') ?? '').trim();
    const subject = encodeURIComponent(cf.subject);
    const body = encodeURIComponent(`Name: ${name}\nEmail: ${email}\n\n${message}`);
    const link = document.createElement('a');
    link.href = `mailto:${contactEmail}?subject=${subject}&body=${body}`;
    link.style.display = 'none';
    document.body.appendChild(link);
    link.click();
    link.remove();
  }

  if (new URLSearchParams(window.location.search).get('sent') === '1') {
    showStatus(cf.successRedirect, 'success');
    window.history.replaceState({}, '', window.location.pathname);
  }

  form?.addEventListener('submit', async (event) => {
    if (!formConfigured) {
      event.preventDefault();
      showStatus(`${cf.notConfigured} ${contactEmail}.`, 'warning');
      openMailto();
      return;
    }

    event.preventDefault();

    const data = new FormData(form);
    const payload = {
      access_key: web3formsAccessKey,
      name: String(data.get('name') ?? '').trim(),
      email: String(data.get('email') ?? '').trim(),
      message: String(data.get('message') ?? '').trim(),
      subject: cf.subject,
      from_name: cf.fromName,
      botcheck: data.get('botcheck'),
    };

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = cf.sending;
    }

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(payload),
      });

      const result = await response.json();
      if (!response.ok || !result.success) throw new Error(result.message || 'Error');

      showStatus(cf.success, 'success');
      form.reset();
    } catch {
      showStatus(`${cf.error} ${contactEmail}.`, 'error');
      openMailto();
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = cf.submit;
      }
    }
  });
</script>
