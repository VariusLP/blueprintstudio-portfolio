---
import { contactEmail, mailtoDefault, mailtoInquiry } from '../data/site';

interface Props {
  heading?: string;
  description?: string;
  showButton?: boolean;
}
const {
  heading = 'Kontakt',
  description = 'Technische Anfragen zu Unity-Projekten, Editor-Tools oder Performance-Optimierung.',
  showButton = true,
} = Astro.props;
---

<section class="px-6 pb-28 sm:px-8" aria-labelledby="contact-title">
  <div class="mx-auto grid max-w-7xl grid-cols-1 items-start gap-16 lg:grid-cols-2 lg:gap-20">
    <div>
      <p class="accent-label mb-4">Anfrage</p>
      <h2 id="contact-title" class="section-title">{heading}</h2>
      <p class="mt-6 max-w-md text-sm font-light leading-relaxed text-neutral-400">
        {description}
      </p>
      <dl class="mt-10 space-y-4 text-sm font-light text-neutral-500">
        <div>
          <dt class="accent-label">Antwortzeit</dt>
          <dd class="mt-1 text-neutral-400">In der Regel innerhalb von 48 Stunden</dd>
        </div>
        <div>
          <dt class="accent-label">Sprachen</dt>
          <dd class="mt-1 text-neutral-400">Deutsch, Englisch</dd>
        </div>
      </dl>
    </div>
    <div class="bento-cell">
      <dl>
        <dt class="accent-label">E-Mail</dt>
        <dd class="mt-4">
          <a
            href={mailtoDefault}
            class="text-xl font-normal text-neutral-100 hover:text-cyan-300/90"
          >
            {contactEmail}
          </a>
        </dd>
      </dl>
      {
        showButton && (
          <div class="mt-10">
            <a
              href={mailtoInquiry}
              class="btn-ghost"
              aria-label={`E-Mail an ${contactEmail} senden — öffnet Ihr E-Mail-Programm`}
              title="Öffnet Ihr Standard-E-Mail-Programm"
            >
              Nachricht senden
            </a>
            <p class="mt-4 text-xs font-light text-neutral-600">
              Öffnet Ihr E-Mail-Programm mit vorausgefülltem Betreff.
            </p>
          </div>
        )
      }
    </div>
  </div>
</section>
