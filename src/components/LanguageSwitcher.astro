---
import { getAlternatePath, type Lang } from '../i18n';
import { withBase } from '../utils/url';

interface Props {
  currentPath: string;
  lang: Lang;
}

const { currentPath, lang } = Astro.props;
const alternatePath = getAlternatePath(currentPath);
const alternateLang = lang === 'de' ? 'en' : 'de';
---

<div class="flex items-center gap-1 rounded-lg border border-white/10 bg-white/[0.03] p-0.5 text-xs font-light">
  <a
    href={withBase(lang === 'de' ? currentPath : alternatePath)}
    class:list={[
      'rounded-md px-2.5 py-1.5 transition-colors',
      lang === 'de' ? 'bg-white/10 text-white' : 'text-neutral-500 hover:text-neutral-300',
    ]}
    aria-current={lang === 'de' ? 'true' : undefined}
    hreflang="de"
  >
    DE
  </a>
  <a
    href={withBase(lang === 'en' ? currentPath : alternatePath)}
    class:list={[
      'rounded-md px-2.5 py-1.5 transition-colors',
      lang === 'en' ? 'bg-white/10 text-white' : 'text-neutral-500 hover:text-neutral-300',
    ]}
    aria-current={lang === 'en' ? 'true' : undefined}
    hreflang="en"
  >
    EN
  </a>
</div>
