---
import { impressum } from '../data/site';
import { withBase } from '../utils/url';

const year = new Date().getFullYear();
---

<footer class="border-t border-white/[0.06] px-6 py-20 sm:px-8">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-12 lg:grid-cols-3 lg:gap-16">
    <div>
      <p class="accent-label">Navigation</p>
      <ul class="mt-4 space-y-2 text-sm font-light">
        <li><a href={withBase('/services')} class="text-neutral-500 hover:text-cyan-300/90">Leistungen</a></li>
        <li><a href={withBase('/assets')} class="text-neutral-500 hover:text-cyan-300/90">Assets</a></li>
        <li><a href={withBase('/portfolio')} class="text-neutral-500 hover:text-cyan-300/90">Portfolio</a></li>
      </ul>
    </div>
    <div>
      <p class="accent-label">Impressum</p>
      <p class="mt-3 text-sm font-light text-neutral-600">{impressum.status}</p>
      <address class="mt-3 not-italic text-sm font-light leading-relaxed text-neutral-500">
        {impressum.company}<br />
        {impressum.owner}<br />
        {impressum.street}<br />
        {impressum.city}, {impressum.country}
      </address>
    </div>
    <div>
      <p class="accent-label">BlueprintStudio</p>
      <p class="mt-3 text-sm font-light leading-relaxed text-neutral-500">
        High-Performance Software &amp; Unity Development.
      </p>
      <p class="mt-8 text-xs font-light text-neutral-700">&copy; {year} BlueprintStudio</p>
    </div>
  </div>
</footer>
