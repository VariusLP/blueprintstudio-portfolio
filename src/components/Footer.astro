---
import { impressum, contactEmail, nav } from '../data/site';
import { withBase } from '../utils/url';

const year = new Date().getFullYear();
---

<footer class="border-t border-white/[0.06] px-4 py-16 pb-[max(4rem,env(safe-area-inset-bottom))] sm:px-8 sm:py-20">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-12 lg:grid-cols-3 lg:gap-16">
    <div>
      <p class="accent-label">Navigation</p>
      <ul class="mt-4 space-y-2 text-sm font-light">
        {
          nav.map((item) => (
            <li>
              <a href={withBase(item.href)} class="text-neutral-500 hover:text-cyan-300/90">
                {item.label}
              </a>
            </li>
          ))
        }
        <li>
          <a href={withBase('/impressum')} class="text-neutral-500 hover:text-cyan-300/90">
            Impressum
          </a>
        </li>
      </ul>
    </div>
    <div>
      <p class="accent-label">Impressum</p>
      <address class="mt-3 not-italic text-sm font-light leading-relaxed text-neutral-500">
        {impressum.owner}<br />
        {impressum.tradeName}<br />
        {impressum.street}<br />
        {impressum.zip} {impressum.city}, {impressum.country}<br />
        <a href={`mailto:${contactEmail}`} class="hover:text-cyan-300/90">{contactEmail}</a>
      </address>
    </div>
    <div>
      <a href={withBase('/')} class="inline-flex items-center gap-3">
        <img
          src={withBase('logo.png')}
          alt=""
          class="brand-asset h-9 w-9"
          width="36"
          height="36"
          aria-hidden="true"
        />
        <span class="text-sm font-extrabold text-white">BlueprintStudio</span>
      </a>
      <p class="mt-3 text-sm font-light leading-relaxed text-neutral-500">
        Full-Cycle Software &amp; Solutions.
      </p>
      <p class="mt-8 text-xs font-light text-neutral-700">&copy; {year} {impressum.owner}</p>
    </div>
  </div>
</footer>
