---
import { heroCodeSnippet } from '../data/site';
---

<div class="glass-panel-glow">
  <div class="glass-panel" aria-hidden="true">
    <div class="mb-4 flex items-center gap-2 border-b border-white/[0.06] pb-4">
      <span class="h-2.5 w-2.5 rounded-full bg-cyan-500/40"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-violet-500/30"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-white/10"></span>
      <span class="ml-2 font-mono text-xs font-light text-neutral-500">
        FrameBudgetProfiler.cs
      </span>
    </div>
    <pre class="overflow-x-auto font-mono text-[0.7rem] leading-[1.75] sm:text-xs"><code set:html={heroCodeSnippet} /></pre>
  </div>
</div>
