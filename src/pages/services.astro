---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
import ContactSection from '../components/ContactSection.astro';
import { services, workflow } from '../data/site';
---

<BaseLayout
  title="Leistungen"
  description="BlueprintStudio Freelancer Services: Unity Performance-Optimierung, Custom Editor Tools, Software-Architektur und IT-Support."
>
  <!-- Intro -->
  <section class="px-6 pb-16 pt-32 sm:px-8" aria-labelledby="services-title">
    <div class="mx-auto max-w-7xl">
      <p class="accent-label mb-4">Freelancer Services</p>
      <h1 id="services-title" class="max-w-3xl section-title">
        Technische Leistungen für Unity &amp; Software.
      </h1>
      <p class="mt-8 max-w-2xl text-base font-light leading-relaxed text-neutral-400">
        Von der Frame-Time-Analyse bis zur maßgeschneiderten Editor-Erweiterung — fokussiert
        auf messbare Performance, wartbare Architektur und effiziente Workflows.
        Alle Leistungen werden als Freelance-Projekte mit klarem Scope abgewickelt.
      </p>
    </div>
  </section>

  <!-- Bento-Übersicht -->
  <section class="px-6 pb-24 sm:px-8" aria-label="Leistungsübersicht">
    <div class="mx-auto max-w-7xl">
      <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:gap-4" role="list">
        {
          services.map((service) => (
            <li class={service.featured ? 'bento-cell-featured' : 'bento-cell'}>
              <ServiceIcon icon={service.icon} />
              <h2 class="text-sm font-extrabold tracking-tight text-neutral-100">
                <a href={`#${service.icon}`} class="hover:text-cyan-300/90">
                  {service.title}
                </a>
              </h2>
              <p class="mt-3 text-sm font-light leading-relaxed text-neutral-500">
                {service.description}
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Detail-Sektionen -->
  {
    services.map((service) => (
      <section
        id={service.icon}
        class="border-t border-white/[0.04] px-6 py-24 sm:px-8"
        aria-labelledby={`detail-${service.icon}`}
      >
        <div class="mx-auto grid max-w-7xl grid-cols-1 gap-16 lg:grid-cols-12 lg:gap-20">
          <div class="lg:col-span-5">
            <ServiceIcon icon={service.icon} />
            <h2 id={`detail-${service.icon}`} class="section-title">
              {service.title}
            </h2>
            <p class="mt-6 text-sm font-light leading-relaxed text-neutral-400">
              {service.details}
            </p>
            <div class="mt-8 flex flex-wrap gap-2">
              {service.technologies.map((tech) => (
                <span class="tag">{tech}</span>
              ))}
            </div>
          </div>
          <div class="lg:col-span-7">
            <div class="bento-cell">
              <h3 class="accent-label">Deliverables</h3>
              <ul class="detail-list" role="list">
                {service.deliverables.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>
    ))
  }

  <!-- Ablauf -->
  <section class="px-6 py-24 sm:px-8" aria-labelledby="workflow-title">
    <div class="mx-auto max-w-7xl">
      <p class="accent-label mb-4">Prozess</p>
      <h2 id="workflow-title" class="section-title mb-12">Projektablauf</h2>
      <ol class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4 lg:gap-4" role="list">
        {
          workflow.map((step) => (
            <li class="bento-cell">
              <span class="accent-label">{step.step}</span>
              <h3 class="mt-3 text-sm font-extrabold text-neutral-100">{step.title}</h3>
              <p class="mt-3 text-sm font-light leading-relaxed text-neutral-500">
                {step.description}
              </p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <ContactSection
    heading="Projekt anfragen"
    description="Beschreiben Sie Ihr Unity-Projekt, den gewünschten Scope und den Zeitrahmen. Ich melde mich mit einer technischen Einschätzung."
  />
</BaseLayout>
