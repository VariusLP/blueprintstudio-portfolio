---
import BaseLayout from '../layouts/BaseLayout.astro';
import { portfolioProjects, openSource, githubUrl, githubHandle } from '../data/site';
import { withBase } from '../utils/url';

function projectHref(project: (typeof portfolioProjects)[number]) {
  if (project.url) return project.url;
  if ('internalUrl' in project && project.internalUrl) return withBase(project.internalUrl);
  return undefined;
}
---

<BaseLayout
  title="Portfolio"
  description="BlueprintStudio Projekt-Portfolio — SaveSystemPro, Project Slimmer, Unity- und Unreal-Projekte."
>
  <section class="px-4 pb-16 pt-28 sm:px-8 sm:pt-32" aria-labelledby="portfolio-title">
    <div class="mx-auto max-w-7xl">
      <p class="accent-label mb-4">BlueprintStudio</p>
      <h1 id="portfolio-title" class="section-title">Portfolio / Projekte</h1>
      <p class="mt-8 max-w-2xl text-sm font-light leading-relaxed text-neutral-400">
        Ausgewählte Projekte — von Asset-Store-Tools über Unity-Simulationen bis zu Unreal- und
        RPG-Prototypen. Die Unity-Tools SaveSystemPro und Project Slimmer sind die ersten
        veröffentlichten Produkte; weitere Editor-Utilities folgen.
      </p>
      <p class="mt-4 max-w-2xl text-sm font-light leading-relaxed text-neutral-500">
        {openSource.workflow}
      </p>
      <a href={githubUrl} class="btn-ghost mt-10" target="_blank" rel="noopener noreferrer">
        github.com/{githubHandle}
      </a>
    </div>
  </section>

  <section class="px-4 pb-24 sm:px-8 sm:pb-28" aria-labelledby="projects-title">
    <div class="mx-auto max-w-7xl">
      <h2 id="projects-title" class="accent-label mb-8">Projekte</h2>
      <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2" role="list">
        {
          portfolioProjects.map((project) => {
            const href = projectHref(project);
            const external = Boolean(project.url);

            return (
              <li class="bento-cell">
                <p class="accent-label">{project.type}</p>
                <h3 class="mt-2 text-base font-extrabold text-neutral-100">
                  {
                    href ? (
                      <a
                        href={href}
                        class="hover:text-cyan-300/90"
                        target={external ? '_blank' : undefined}
                        rel={external ? 'noopener noreferrer' : undefined}
                      >
                        {project.name}
                      </a>
                    ) : (
                      project.name
                    )
                  }
                </h3>
                <p class="mt-3 text-sm font-light leading-relaxed text-neutral-500">
                  {project.description}
                </p>
                <ul class="mt-4 flex flex-wrap gap-2" role="list">
                  {project.tags.map((tag) => (
                    <li class="tag">{tag}</li>
                  ))}
                </ul>
              </li>
            );
          })
        }
      </ul>
    </div>
  </section>
</BaseLayout>
