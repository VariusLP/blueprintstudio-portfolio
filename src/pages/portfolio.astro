---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactSection from '../components/ContactSection.astro';
import { githubUrl, githubHandle, projects, skills, studio, openSource } from '../data/site';
---

<BaseLayout
  title="Portfolio"
  description="BlueprintStudio Portfolio — technische Arbeit, Unity Tools und Open-Source-Projekte auf GitHub."
>
  <!-- Intro -->
  <section class="px-6 pb-16 pt-32 sm:px-8" aria-labelledby="portfolio-title">
    <div class="mx-auto max-w-7xl">
      <p class="accent-label mb-4">GitHub &amp; Projekte</p>
      <h1 id="portfolio-title" class="max-w-3xl section-title">Portfolio</h1>
      <p class="mt-8 max-w-2xl text-base font-light leading-relaxed text-neutral-400">
        Einblick in technische Arbeit, Unity-Tools und Open-Source-Projekte von {studio.owner}.
        Schwerpunkt: Editor-Erweiterungen, Performance-Tools und produktive Asset-Store-Lösungen.
      </p>
      <a href={githubUrl} class="btn-ghost mt-10" rel="noopener noreferrer">
        GitHub-Profil öffnen
      </a>
    </div>
  </section>

  <!-- Über mich -->
  <section class="px-6 py-24 sm:px-8" aria-labelledby="profile-title">
    <div class="mx-auto max-w-7xl">
      <div class="glass-panel-glow">
        <div class="glass-panel grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-16">
          <div>
            <p class="accent-label mb-4">Entwickler</p>
            <h2 id="profile-title" class="section-title">{studio.owner}</h2>
            <p class="mt-2 text-sm font-light text-neutral-500">{studio.tradeName}</p>
          </div>
          <div>
            <p class="text-sm font-light leading-relaxed text-neutral-400">
              Unity-Entwickler mit Fokus auf Editor-Tools, Performance-Engineering und
              skalierbare C#-Architekturen. Gründer von BlueprintStudio. Arbeitet mit
              Teams und Einzelentwicklern an technisch anspruchsvollen Unity-Projekten.
            </p>
            <p class="mt-6 text-sm font-light leading-relaxed text-neutral-500">
              {studio.location} · Remote &amp; vor Ort
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projekte -->
  <section class="px-6 py-24 sm:px-8" aria-labelledby="projects-title">
    <div class="mx-auto max-w-7xl">
      <p class="accent-label mb-4">Arbeiten</p>
      <h2 id="projects-title" class="section-title mb-12">Projekte</h2>
      <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:gap-4" role="list">
        {
          projects.map((project) => (
            <li class="bento-cell">
              <p class="accent-label">{project.type}</p>
              <h3 class="mt-2 text-base font-extrabold text-neutral-100">
                <a
                  href={project.url}
                  class="hover:text-cyan-300/90"
                  rel="noopener noreferrer"
                >
                  {project.name}
                </a>
              </h3>
              <p class="mt-3 text-sm font-light leading-relaxed text-neutral-500">
                {project.description}
              </p>
              <ul class="mt-4 flex flex-wrap gap-2" role="list">
                {project.tags.map((tag) => (
                  <li class="tag">{tag}</li>
                ))}
              </ul>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Skills -->
  <section class="px-6 py-24 sm:px-8" aria-labelledby="skills-title">
    <div class="mx-auto max-w-7xl">
      <p class="accent-label mb-4">Expertise</p>
      <h2 id="skills-title" class="section-title mb-12">Skills &amp; Schwerpunkte</h2>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4 lg:gap-4">
        {
          skills.map((group) => (
            <div class="bento-cell">
              <h3 class="text-sm font-extrabold text-neutral-100">{group.category}</h3>
              <ul class="detail-list mt-4" role="list">
                {group.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- GitHub & Open Source -->
  <section class="px-6 pb-8 sm:px-8" aria-labelledby="github-title">
    <div class="mx-auto max-w-7xl">
      <div class="glass-panel-glow">
        <div class="glass-panel grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
          <div>
            <p class="accent-label mb-4">Open Source</p>
            <h2 id="github-title" class="section-title">GitHub-Workflow</h2>
            <p class="mt-6 text-sm font-light leading-relaxed text-neutral-400">
              {openSource.workflow}
            </p>
            <p class="mt-4 text-sm font-light leading-relaxed text-neutral-500">
              {openSource.approach}
            </p>
            <p class="mt-6 font-mono text-xs font-light text-neutral-600">
              github.com/{githubHandle}
            </p>
          </div>
          <div class="lg:text-right">
            <a href={githubUrl} class="btn-ghost" rel="noopener noreferrer">
              Repository ansehen
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactSection
    heading="Zusammenarbeit"
    description="Interesse an einem Freelance-Projekt, einer Performance-Analyse oder einem Custom Editor Tool? Kontaktieren Sie mich mit einer kurzen Projektbeschreibung."
  />
</BaseLayout>
