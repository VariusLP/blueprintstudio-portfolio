---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactSection from '../components/ContactSection.astro';
import { assets } from '../data/site';
---

<BaseLayout
  title="Assets"
  description="BlueprintStudio Unity Store Tools: SaveSystemPro und Project Slimmer — performante Lösungen für Unity-Entwickler."
>
  <!-- Intro -->
  <section class="px-6 pb-16 pt-32 sm:px-8" aria-labelledby="assets-title">
    <div class="mx-auto max-w-7xl">
      <p class="accent-label mb-4">Unity Asset Store</p>
      <h1 id="assets-title" class="max-w-3xl section-title">Assets</h1>
      <p class="mt-8 max-w-2xl text-base font-light leading-relaxed text-neutral-400">
        Produktive Tools für Unity-Entwickler — modular aufgebaut, auf Performance und
        Build-Größe optimiert. Alle Assets werden von BlueprintStudio entwickelt und
        gepflegt. Asset-Store-Links folgen nach Veröffentlichung.
      </p>
    </div>
  </section>

  <!-- Asset-Details -->
  {
    assets.map((asset, index) => (
      <section
        id={asset.slug}
        class:list={[
          'px-6 py-24 sm:px-8',
          index > 0 && 'border-t border-white/[0.04]',
        ]}
        aria-labelledby={`asset-${asset.slug}`}
      >
        <div class="mx-auto max-w-7xl">
          <div class="grid grid-cols-1 gap-16 lg:grid-cols-2 lg:gap-20">
            <div class={asset.featured ? 'lg:order-2' : ''}>
              <div class:list={[asset.featured ? 'bento-cell-featured' : 'bento-cell', 'h-full']}>
                <p class="accent-label">{asset.version}</p>
                <h2 id={`asset-${asset.slug}`} class="mt-3 text-2xl font-extrabold text-neutral-50">
                  {asset.name}
                </h2>
                <p class="mt-6 text-sm font-light leading-relaxed text-neutral-400">
                  {asset.summary}
                </p>
                <a
                  href={asset.url}
                  class="btn-ghost mt-10"
                  rel="noopener noreferrer"
                >
                  Im Asset Store ansehen
                </a>
              </div>
            </div>

            <div class={asset.featured ? 'lg:order-1' : ''}>
              <h3 class="accent-label mb-6">Features</h3>
              <ul class="detail-list" role="list">
                {asset.features.map((feature) => (
                  <li>{feature}</li>
                ))}
              </ul>

              <h3 class="accent-label mb-4 mt-12">Kompatibilität</h3>
              <ul class="flex flex-wrap gap-2" role="list">
                {asset.compatibility.map((item) => (
                  <li class="tag">{item}</li>
                ))}
              </ul>

              <div class="bento-cell mt-8">
                <h3 class="accent-label">Kurzbeschreibung</h3>
                <p class="mt-3 text-sm font-light leading-relaxed text-neutral-500">
                  {asset.description}
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>
    ))
  }

  <!-- Vergleich -->
  <section class="border-t border-white/[0.04] px-6 py-24 sm:px-8" aria-labelledby="compare-title">
    <div class="mx-auto max-w-7xl">
      <p class="accent-label mb-4">Übersicht</p>
      <h2 id="compare-title" class="section-title mb-12">Asset-Vergleich</h2>
      <div class="overflow-x-auto">
        <table class="w-full min-w-[32rem] text-left text-sm font-light">
          <thead>
            <tr class="border-b border-white/10 text-neutral-500">
              <th class="pb-4 pr-6 font-normal">Asset</th>
              <th class="pb-4 pr-6 font-normal">Zweck</th>
              <th class="pb-4 font-normal">Einsatz</th>
            </tr>
          </thead>
          <tbody class="text-neutral-400">
            <tr class="border-b border-white/[0.04]">
              <td class="py-4 pr-6 font-extrabold text-neutral-200">SaveSystemPro</td>
              <td class="py-4 pr-6">Datenpersistenz</td>
              <td class="py-4">Runtime — Save/Load in Spielen</td>
            </tr>
            <tr>
              <td class="py-4 pr-6 font-extrabold text-neutral-200">Project Slimmer</td>
              <td class="py-4 pr-6">Projekt-Optimierung</td>
              <td class="py-4">Editor — Build-Size &amp; Cleanup</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <ContactSection
    heading="Fragen zu Assets"
    description="Support-Anfragen, Feature-Wünsche oder Lizenzfragen zu SaveSystemPro und Project Slimmer."
  />
</BaseLayout>
