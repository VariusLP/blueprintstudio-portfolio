---
import BaseLayout from '../layouts/BaseLayout.astro';
import { assets } from '../data/site';
import { withBase } from '../utils/url';
---

<BaseLayout
  title="Assets"
  description="SaveSystemPro und Project Slimmer — Unity Asset Store Tools von BlueprintStudio."
>
  <section class="px-4 pb-24 pt-28 sm:px-8 sm:pb-28 sm:pt-32" aria-labelledby="assets-title">
    <div class="mx-auto max-w-7xl">
      <p class="accent-label mb-4">Unity Asset Store</p>
      <h1 id="assets-title" class="section-title">Assets / Shop</h1>
      <p class="mt-8 max-w-2xl text-sm font-light leading-relaxed text-neutral-400">
        Direktlinks zu den Unity Asset Store Produkten. Technische Anleitungen findest du
        unter Dokumentation.
      </p>

      <ul class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-2 sm:mt-16" role="list">
        {
          assets.map((asset) => (
            <li class="bento-cell">
              <p class="accent-label">{asset.version}</p>
              <h2 class="mt-2 text-xl font-extrabold text-neutral-50">{asset.name}</h2>
              <p class="mt-4 text-sm font-light leading-relaxed text-neutral-400">
                {asset.summary}
              </p>
              <ul class="detail-list mt-6" role="list">
                {asset.features.map((feature) => (
                  <li>{feature}</li>
                ))}
              </ul>
              <div class="mt-8 flex flex-wrap gap-3">
                <a href={asset.storeUrl} class="btn-ghost" rel="noopener noreferrer">
                  Unity Asset Store
                </a>
                <a href={withBase(`/docs/${asset.slug}`)} class="btn-ghost">
                  Dokumentation
                </a>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
