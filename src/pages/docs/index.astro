---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { docs } from '../../data/site';
import { withBase } from '../../utils/url';
---

<BaseLayout
  title="Dokumentation"
  description="Technische Dokumentation für SaveSystemPro und Project Slimmer."
>
  <section class="px-6 pb-28 pt-32 sm:px-8" aria-labelledby="docs-title">
    <div class="mx-auto max-w-7xl">
      <p class="accent-label mb-4">Wiki</p>
      <h1 id="docs-title" class="section-title">Dokumentation</h1>
      <p class="mt-8 max-w-2xl text-sm font-light leading-relaxed text-neutral-400">
        Technische Anleitungen für Setup, Workflow und Architektur der BlueprintStudio-Tools.
        Wähle ein Produkt aus dem Untermenü oder hier direkt.
      </p>

      <ul class="mt-16 grid grid-cols-1 gap-4 sm:grid-cols-2" role="list">
        {
          docs.map((doc) => (
            <li class="bento-cell">
              <h2 class="text-lg font-extrabold text-neutral-100">
                <a href={withBase(`/docs/${doc.slug}`)} class="hover:text-cyan-300/90">
                  {doc.title}
                </a>
              </h2>
              <p class="mt-4 text-sm font-light leading-relaxed text-neutral-500">{doc.intro}</p>
              <a href={withBase(`/docs/${doc.slug}`)} class="btn-ghost mt-8">
                Anleitung öffnen
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
