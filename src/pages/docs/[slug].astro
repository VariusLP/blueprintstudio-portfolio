---
import DocDetailPage from '../../components/pages/DocDetailPage.astro';
import { de } from '../../i18n';

export function getStaticPaths() {
  return de.assets.map((doc) => ({ params: { slug: doc.slug }, props: { doc } }));
}

const { doc } = Astro.props;
---

<DocDetailPage lang="de" doc={doc} />
