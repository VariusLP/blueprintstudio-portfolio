---
import BaseLayout from '../layouts/BaseLayout.astro';
import { contactEmail, impressum } from '../data/site';
---

<BaseLayout
  title="Impressum"
  description="Impressum und Anbieterkennzeichnung von BlueprintStudio — Sascha Leitner, Münzbach, Österreich."
>
  <section class="px-4 pb-24 pt-28 sm:px-8 sm:pb-28 sm:pt-32" aria-labelledby="impressum-title">
    <div class="mx-auto max-w-3xl">
      <p class="accent-label mb-4">Rechtliches</p>
      <h1 id="impressum-title" class="section-title">Impressum</h1>
      <p class="mt-6 text-sm font-light text-neutral-500">
        Angaben gemäß § 5 ECG und § 25 MedienG (Österreich)
      </p>

      <div class="mt-16 space-y-12">
        <div>
          <h2 class="accent-label mb-4">Medieninhaber und Herausgeber</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-300">{impressum.owner}</p>
        </div>

        <div>
          <h2 class="accent-label mb-4">Unternehmensbezeichnung</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-300">
            {impressum.tradeName} (Marken- und Projektname)
          </p>
        </div>

        <div>
          <h2 class="accent-label mb-4">Beruf</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-300">{impressum.profession}</p>
        </div>

        <div>
          <h2 class="accent-label mb-4">Anschrift</h2>
          <address class="not-italic text-sm font-light leading-relaxed text-neutral-300">
            {impressum.street}<br />
            {impressum.zip} {impressum.city}<br />
            {impressum.country}
          </address>
        </div>

        <div>
          <h2 class="accent-label mb-4">Kontakt</h2>
          <p class="text-sm font-light text-neutral-300">
            E-Mail:
            <a href={`mailto:${contactEmail}`} class="text-neutral-100 hover:text-cyan-300/90">
              {contactEmail}
            </a>
          </p>
        </div>

        <div>
          <h2 class="accent-label mb-4">Firmenbuch</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-400">{impressum.firmenbuch}</p>
        </div>

        <div>
          <h2 class="accent-label mb-4">UID-Nummer</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-400">{impressum.uid}</p>
        </div>

        <div class="bento-cell">
          <h2 class="accent-label mb-4">Datenschutz / Webanalyse</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-500">
            Diese Website verwendet Umami Analytics — eine cookie-freie, anonymisierte
            Reichweitenmessung. Es werden keine personenbezogenen Profile erstellt und keine
            Daten an Werbenetzwerke weitergegeben. Die Auswertung ist nur für den Betreiber
            dieser Website zugänglich. Rechtsgrundlage: berechtigtes Interesse gemäß Art. 6
            Abs. 1 lit. f DSGVO (technische Optimierung der Website).
          </p>
          <h2 class="accent-label mb-4 mt-8">Haftung für Inhalte</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-500">
            Die Inhalte dieser Website wurden mit größter Sorgfalt erstellt. Für die Richtigkeit,
            Vollständigkeit und Aktualität der Inhalte kann jedoch keine Gewähr übernommen werden.
          </p>
          <h2 class="accent-label mb-4 mt-8">Haftung für Links</h2>
          <p class="text-sm font-light leading-relaxed text-neutral-500">
            Diese Website enthält Links zu externen Websites Dritter. Auf deren Inhalte habe ich
            keinen Einfluss. Für die Inhalte der verlinkten Seiten ist stets der jeweilige Anbieter
            verantwortlich.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
