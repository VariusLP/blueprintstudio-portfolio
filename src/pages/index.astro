---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCodePanel from '../components/HeroCodePanel.astro';
import { studio } from '../data/site';
import { withBase } from '../utils/url';
---

<BaseLayout title="BlueprintStudio">
  <section
    class="flex min-h-[100dvh] min-h-screen items-center px-4 pb-24 pt-28 sm:px-8 sm:pb-28 sm:pt-32"
    aria-labelledby="hero-title"
  >
    <div class="mx-auto grid w-full max-w-7xl grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-14">
      <div>
      <div>
        <img
          src={withBase('banner.png')}
          alt="BlueprintStudio"
          class="w-full max-w-sm"
          width="640"
          height="160"
          loading="eager"
          fetchpriority="high"
        />
        <h1
          id="hero-title"
          class="mt-8 text-left text-[clamp(1.5rem,4.5vw,2.25rem)] font-extrabold leading-tight tracking-tight text-white"
        >
          {studio.role}
        </h1>
        <p class="mt-6 max-w-lg text-base font-light leading-relaxed text-neutral-400">
          {studio.tagline}. {studio.intro}
        </p>
        <p class="mt-6 max-w-lg text-sm font-light leading-relaxed text-neutral-500">
          {studio.why}
        </p>
        <div class="mt-12 flex flex-wrap gap-4">
          <a href={withBase('/assets')} class="btn-ghost">Unity Assets</a>
          <a href={withBase('/kontakt')} class="btn-ghost">Projekt anfragen</a>
        </div>
      </div>
      <HeroCodePanel />
    </div>
  </section>
</BaseLayout>
