---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCodePanel from '../components/HeroCodePanel.astro';
import { studio } from '../data/site';
import { withBase } from '../utils/url';
---

<BaseLayout title="BlueprintStudio">
  <section
    class="flex min-h-screen items-center px-6 pb-28 pt-32 sm:px-8"
    aria-labelledby="hero-title"
  >
    <div class="mx-auto grid w-full max-w-7xl grid-cols-1 items-center gap-16 lg:grid-cols-2 lg:gap-14">
      <div>
        <span class="hero-badge">Unity · Algorithmen · Performance</span>
        <h1
          id="hero-title"
          class="text-left text-[clamp(2.5rem,5vw,4rem)] font-extrabold leading-[1.06] tracking-[-0.03em] text-white"
        >
          {studio.name} — {studio.tagline}
        </h1>
        <p class="mt-8 max-w-lg text-base font-light leading-relaxed text-neutral-400">
          {studio.intro}
        </p>
        <p class="mt-6 max-w-lg text-sm font-light leading-relaxed text-neutral-500">
          {studio.why}
        </p>
        <div class="mt-12 flex flex-wrap gap-4">
          <a href={withBase('/assets')} class="btn-ghost">Assets ansehen</a>
          <a href={withBase('/portfolio')} class="btn-ghost">Portfolio</a>
        </div>
      </div>
      <HeroCodePanel />
    </div>
  </section>
</BaseLayout>
