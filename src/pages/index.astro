---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCodePanel from '../components/HeroCodePanel.astro';
import ContactSection from '../components/ContactSection.astro';
import { studio, focusAreas, techStack } from '../data/site';
import { withBase } from '../utils/url';
---

<BaseLayout title="BlueprintStudio">
  <!-- Hero -->
  <section
    class="flex min-h-[90vh] items-center px-6 pb-20 pt-32 sm:px-8"
    aria-labelledby="hero-title"
  >
    <div class="mx-auto grid w-full max-w-7xl grid-cols-1 items-center gap-16 lg:grid-cols-2 lg:gap-14">
      <div>
        <span class="hero-badge">Unity · Editor Tools · Performance</span>
        <h1
          id="hero-title"
          class="text-left text-[clamp(2.5rem,5vw,4rem)] font-extrabold leading-[1.06] tracking-[-0.03em] text-white"
        >
          {studio.name} – {studio.tagline}.
        </h1>
        <p class="mt-8 max-w-lg text-base font-light leading-relaxed text-neutral-400">
          {studio.summary}
        </p>
        <div class="mt-12 flex flex-wrap gap-4">
          <a href={withBase('/portfolio')} class="btn-ghost">Projekt anfragen</a>
          <a href={withBase('/services')} class="btn-ghost">Leistungen ansehen</a>
        </div>
      </div>
      <HeroCodePanel />
    </div>
  </section>

  <!-- Über BlueprintStudio -->
  <section class="px-6 py-24 sm:px-8" aria-labelledby="about-title">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 gap-16 lg:grid-cols-12 lg:gap-20">
        <div class="lg:col-span-4">
          <p class="accent-label mb-4">Studio</p>
          <h2 id="about-title" class="section-title">Über BlueprintStudio</h2>
        </div>
        <div class="lg:col-span-8">
          <p class="max-w-2xl text-sm font-light leading-relaxed text-neutral-400">
            BlueprintStudio ist ein Ein-Personen-Studio unter der Leitung von {studio.owner}.
            Schwerpunkt ist die technische Umsetzung anspruchsvoller Unity-Projekte — von der
            Performance-Analyse bis zur fertigen Editor-Erweiterung. Kein Agentur-Overhead,
            direkte Kommunikation, fokussierte Ergebnisse.
          </p>
          <p class="mt-6 max-w-2xl text-sm font-light leading-relaxed text-neutral-500">
            Standort: {studio.location}. Zusammenarbeit remote oder vor Ort nach Absprache.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Schwerpunkte -->
  <section class="px-6 py-24 sm:px-8" aria-labelledby="focus-title">
    <div class="mx-auto max-w-7xl">
      <p class="accent-label mb-4">Schwerpunkte</p>
      <h2 id="focus-title" class="section-title mb-12">Technische Kernbereiche</h2>
      <ul class="grid grid-cols-1 gap-3 md:grid-cols-3 md:gap-4" role="list">
        {
          focusAreas.map((area) => (
            <li class="bento-cell">
              <h3 class="text-sm font-extrabold text-neutral-100">{area.title}</h3>
              <p class="mt-4 text-sm font-light leading-relaxed text-neutral-500">
                {area.description}
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="px-6 py-24 sm:px-8" aria-labelledby="stack-title">
    <div class="mx-auto max-w-7xl">
      <div class="glass-panel-glow">
        <div class="glass-panel">
          <p class="accent-label mb-4">Technologien</p>
          <h2 id="stack-title" class="section-title">Tech Stack</h2>
          <p class="mt-6 max-w-2xl text-sm font-light leading-relaxed text-neutral-400">
            Primärer Stack für Unity-Entwicklung und Editor-Tools. Erweiterbar je nach
            Projektanforderung.
          </p>
          <ul class="mt-10 grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3" role="list">
            {
              techStack.map((tech) => (
                <li class="tag">{tech}</li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Schnellzugriff -->
  <section class="px-6 py-24 sm:px-8" aria-labelledby="links-title">
    <div class="mx-auto max-w-7xl">
      <p class="accent-label mb-4">Weitere Seiten</p>
      <h2 id="links-title" class="section-title mb-12">Mehr erfahren</h2>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-3 sm:gap-4">
        <a href={withBase('/services')} class="bento-cell group block">
          <h3 class="text-sm font-extrabold text-neutral-100 group-hover:text-cyan-300/90">
            Leistungen
          </h3>
          <p class="mt-3 text-sm font-light text-neutral-500">
            Performance, Editor Tools, Architektur &amp; Support.
          </p>
        </a>
        <a href={withBase('/assets')} class="bento-cell group block">
          <h3 class="text-sm font-extrabold text-neutral-100 group-hover:text-cyan-300/90">
            Assets
          </h3>
          <p class="mt-3 text-sm font-light text-neutral-500">
            SaveSystemPro &amp; Project Slimmer im Unity Asset Store.
          </p>
        </a>
        <a href={withBase('/portfolio')} class="bento-cell group block">
          <h3 class="text-sm font-extrabold text-neutral-100 group-hover:text-cyan-300/90">
            Portfolio
          </h3>
          <p class="mt-3 text-sm font-light text-neutral-500">
            Projekte, Open Source und GitHub-Profil.
          </p>
        </a>
      </div>
    </div>
  </section>

  <ContactSection />
</BaseLayout>
